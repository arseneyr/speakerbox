{
  "name": "speakerbox",
  "version": "0.0.1",
  "scripts": {
    "dev": "svelte-kit dev",
    "build": "svelte-kit build",
    "start": "svelte-kit start",
    "lint": "eslint --ignore-path .gitignore .",
    "storybook": "start-storybook -p 6006",
    "build-storybook": "build-storybook",
    "prepare": "npm run vite-workaround && npm run smui-theme-light && npm run smui-theme-dark",
    "vite-workaround": "find node_modules/@material/ -name \"*.js.map\" -type f -delete",
    "smui-theme-light": "sass --no-source-map -I src/theme -I node_modules src/app.scss static/smui.css",
    "smui-theme-dark": "sass --no-source-map -I src/theme/dark -I node_modules src/app.scss static/smui-dark.css"
  },
  "devDependencies": {
    "@babel/core": "^7.13.15",
    "@storybook/addon-actions": "^6.2.8",
    "@storybook/addon-essentials": "^6.2.8",
    "@storybook/addon-links": "^6.2.8",
    "@storybook/addon-svelte-csf": "^1.0.0",
    "@storybook/preset-scss": "^1.0.3",
    "@storybook/svelte": "^6.2.8",
    "@sveltejs/adapter-node": "^1.0.0-next.16",
    "@sveltejs/kit": "^1.0.0-next.84",
    "@typescript-eslint/eslint-plugin": "^4.19.0",
    "@typescript-eslint/parser": "^4.19.0",
    "babel-loader": "^8.2.2",
    "css-loader": "^5.2.0",
    "eslint": "^7.22.0",
    "eslint-plugin-svelte3": "^3.1.0",
    "faker": "^5.5.3",
    "prettier-plugin-svelte": "^2.2.0",
    "sass": "^1.32.8",
    "sass-loader": "^10",
    "style-loader": "^2.0.0",
    "svelte": "^3.37.0",
    "svelte-loader": "^3.1.0",
    "svelte-preprocess": "^4.0.0",
    "tslib": "^2.0.0",
    "typescript": "^4.0.0",
    "vite": "^2.1.0"
  },
  "type": "module",
  "dependencies": {
    "@smui/button": "^3.0.0-beta.4",
    "@smui/icon-button": "^3.0.0-beta.4",
    "@smui/list": "^3.1.0",
    "@smui/menu": "^3.1.0",
    "gridstack": "^4.1.0",
    "localforage": "^1.9.0",
    "normalize.css": "^8.0.1",
    "uuid": "^8.3.2"
  }
}
